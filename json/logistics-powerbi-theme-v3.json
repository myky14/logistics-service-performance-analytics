{
  "name": "Logistics Executive Theme v3",
  "dataColors": [
    "#D92D20",
    "#F4C400",
    "#1F9D55",
    "#F97316",
    "#344054",
    "#667085",
    "#98A2B3",
    "#0F766E"
  ],
  "background": "#F5F6F8",
  "foreground": "#222222",
  "tableAccent": "#D92D20",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#222222"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "fontSize": 12,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#E6E8EB"
              }
            },
            "radius": 8
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ]
      }
    }
  },
  "textClasses": {
    "title": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 18,
      "color": "#222222"
    },
    "header": {
      "fontFace": "Segoe UI Semibold",
      "fontSize": 14,
      "color": "#222222"
    },
    "label": {
      "fontFace": "Segoe UI",
      "fontSize": 10,
      "color": "#666666"
    }
  }
}